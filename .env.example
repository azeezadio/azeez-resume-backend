NODE_ENV=development
APP_NAME=azeez-resume-backend
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1

DATABASE_URL=postgres://postgres:postgres@localhost:5432/azeez_resume
DB_POOL_MIN=2
DB_POOL_MAX=10

CORS_ORIGIN=*

S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BUCKET=resume-public
S3_PRIVATE_BUCKET=resume-private
S3_FORCE_PATH_STYLE=true

# Railway bucket Add to Service variables are also supported directly:
ENDPOINT=
REGION=auto
BUCKET=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
